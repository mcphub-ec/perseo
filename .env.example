# ─── Perseo MCP Server ─────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# API Key proporcionada por Perseo (panel de administración).
PERSEO_API_KEY=

# Hostname del servidor Perseo de tu cliente.
# Ejemplo: perseo-data-c1.app
PERSEO_URL_SERVIDOR=

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
